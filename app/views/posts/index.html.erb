<div class="page-header">
  <h2>Posts</h2>
</div>

<p class="mb-2"><a href="<%= new_post_path %>" class="btn btn-primary">Create New Post</a></p>

<% @posts.each do |post| %>
  <div class="post-card">
    <h3><a href="<%= post_path(post) %>"><%= post.title %></a></h3>
    <p><%= truncate(post.body, length: 200) %></p>
    <span class="post-meta">Posted at <%= post.created_at.strftime("%Y-%m-%d %H:%M") %></span>
  </div>
<% end %>
