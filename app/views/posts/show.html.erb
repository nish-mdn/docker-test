<div class="card">
  <div class="page-header">
    <h2><%= @post.title %></h2>
  </div>
  <div class="post-content">
    <%= simple_format(@post.body) %>
  </div>
  <div class="post-actions">
    <a href="<%= edit_post_path(@post) %>" class="btn btn-secondary">Edit</a>
    <a href="<%= posts_path %>" class="btn btn-secondary">Back to posts</a>
  </div>
</div>

<div class="comments-section">
  <h3>Comments</h3>

  <% @post.comments.order(created_at: :asc).each do |c| %>
    <div class="comment-card">
      <p><%= c.body %></p>
      <div class="comment-meta">
        <small><%= c.created_at.strftime("%Y-%m-%d %H:%M") %></small>
        <form action="<%= post_comment_path(@post, c) %>" method="post" style="display:inline;">
          <input type="hidden" name="_method" value="delete">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit" class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  <% end %>

  <div class="card mt-2">
    <h4 class="mb-1">Add a comment</h4>
    <%= form_with(model: [@post, @comment], local: true) do |f| %>
      <div class="form-group">
        <%= f.label :body %>
        <%= f.text_area :body, rows: 3 %>
      </div>
      <div>
        <%= f.submit "Add Comment", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
